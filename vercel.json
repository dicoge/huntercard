{
  "functions": {
    "api/**/*.ts": { "runtime": "@vercel/edge@3.0.0" }
  },
  "buildCommand": "expo export --platform web && node scripts/fix-html.js && node scripts/copy-assets.js",
  "outputDirectory": "dist",
  "rewrites": [
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ],
  "crons": [
    {
      "path": "/api/cron/update-db",
      "schedule": "0 2 * * *"
    }
  ]
}
